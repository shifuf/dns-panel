# DNS Panel 环境配置文件
# 将此文件复制为 .env 并根据需要修改配置

# ==========================================
# 🔴 必须设置的环境变量（生产环境）
# ==========================================

# JWT 密钥（用于生成用户登录令牌，请务必修改为随机字符串，至少32字符）
# ⚠️ 注意：此密钥必须与本地开发环境 server/.env 中的值一致，否则登录令牌无法跨环境使用
JWT_SECRET=dev-jwt-secret-key-min-32-char-123456

# 加密密钥（用于加密 DNS 凭证，必须是 32 字符）
# ⚠️ 关键：此密钥必须与本地开发环境 server/.env 中的值完全一致！
# 如果不一致，本地录入的凭证在服务器上将无法解密，反之亦然。
# 迁移/备份数据库到新服务器时也必须携带相同的密钥。
ENCRYPTION_KEY=12345678901234567890123456789012

# ==========================================
# 🟡 建议设置的环境变量
# ==========================================

# 数据库路径（SQLite 数据库文件位置，默认为 /app/db/database.db）
DATABASE_URL=file:/app/db/database.db

# CORS 允许的源（生产环境请修改为你的实际域名）
CORS_ORIGIN=http://localhost:8080

# ==========================================
# 🟢 可选的环境变量
# ==========================================

# 运行环境
NODE_ENV=production

# 后端服务端口
PORT=4001

# JWT 过期时间
JWT_EXPIRES_IN=7d

# 日志保留天数
LOG_RETENTION_DAYS=90
